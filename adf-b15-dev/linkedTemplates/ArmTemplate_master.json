{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-b15-dev"
		},
		"ls_adls_source_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_source'"
		},
		"ls_source_sql_database_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_source_sql_database'"
		},
		"ls_sql_systemIdentity_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_sql_systemIdentity'",
			"defaultValue": "Integrated Security=False;Encrypt=True;Connection Timeout=30;Data Source=sqlserverb15dev.database.windows.net;Initial Catalog=sqldbdev"
		},
		"ls_target_db_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_target_db'"
		},
		"RestService1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://reqres.in/api/users"
		},
		"ls_AzureKeyVault1_sql_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://adf-keyvault-b15-dev.vault.azure.net/"
		},
		"ls_RestAPI_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://reqres.in/api/users"
		},
		"ls_adls_source_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsgen2b15.dfs.core.windows.net"
		},
		"ls_source_sql_database_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverb15dev.database.windows.net"
		},
		"ls_source_sql_database_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldbdev"
		},
		"ls_source_sql_database_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "venkysura"
		},
		"ls_sql_keyvault_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "sqldbsecretb15"
		},
		"ls_target_db_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverb15dev.database.windows.net"
		},
		"ls_target_db_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "targetsqldbdev"
		},
		"ls_target_db_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "venkysura"
		},
		"Tumbling_window_trigger_properties_pipeline_parameters_StartDate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowStartTime"
		},
		"Tumbling_window_trigger_properties_pipeline_parameters_EndDate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndTime"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-b15-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
