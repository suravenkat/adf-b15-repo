						"value": "[parameters('ls_source_sql_database_properties_typeProperties_server')]"
					},
					"ls_source_sql_database_properties_typeProperties_database": {
						"value": "[parameters('ls_source_sql_database_properties_typeProperties_database')]"
					},
					"ls_source_sql_database_properties_typeProperties_userName": {
						"value": "[parameters('ls_source_sql_database_properties_typeProperties_userName')]"
					},
					"ls_target_db_properties_typeProperties_server": {
						"value": "[parameters('ls_target_db_properties_typeProperties_server')]"
					},
					"ls_target_db_properties_typeProperties_database": {
						"value": "[parameters('ls_target_db_properties_typeProperties_database')]"
					},
					"ls_target_db_properties_typeProperties_userName": {
						"value": "[parameters('ls_target_db_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-b15-dev_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-b15-dev_ArmTemplate_0')]"
			]
		},
		{
			"name": "adf-b15-dev_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-b15-dev_ArmTemplate_1')]"
			]
		},
		{
			"name": "adf-b15-dev_ArmTemplate_3",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_3.json', parameters('containerSasToken'))]",
