				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Tumbling_window_trigger_properties_pipeline_parameters_StartDate": {
						"value": "[parameters('Tumbling_window_trigger_properties_pipeline_parameters_StartDate')]"
					},
					"Tumbling_window_trigger_properties_pipeline_parameters_EndDate": {
						"value": "[parameters('Tumbling_window_trigger_properties_pipeline_parameters_EndDate')]"
					}
